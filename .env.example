# Telegram Bot
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your_random_secret_string

# Web server
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# Database (used directly by bot; docker-compose overrides this for the container)
DATABASE_URL=postgresql+asyncpg://vpnbot:vpnbot@localhost:5432/vpnbot

# Postgres (used by docker-compose)
POSTGRES_DB=vpnbot
POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=vpnbot

# Links
SUPPORT_USERNAME=your_support_username
REVIEWS_LINK=https://t.me/your_reviews_group
RULES_LINK=https://telegra.ph/your-rules
TERMS_LINK=https://telegra.ph/your-terms

# VPN config
VPN_CONFIG_PATH=vpn_config.json
